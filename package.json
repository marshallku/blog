{
    "name": "blog",
    "version": "0.5.0",
    "type": "module",
    "private": true,
    "description": "Monorepo for blog SSG and frontend tooling",
    "scripts": {
        "assets": "node scripts/assets.js",
        "build": "pnpm -r build",
        "dev": "pnpm -r dev",
        "clean": "pnpm -r clean",
        "typecheck": "pnpm -r typecheck",
        "manifest": "node scripts/manifest.js",
        "copy-assets": "node scripts/copy-assets.js",
        "build:assets": "pnpm build && pnpm manifest && pnpm copy-assets",
        "changeset": "changeset",
        "version": "changeset version && pnpm manifest",
        "release": "pnpm build:assets",
        "format": "prettier --write \"packages/**/*.{ts,tsx,js,mjs,cjs,scss,css,json}\" \"scripts/**/*.{js,mjs,cjs}\" \"*.{json,yml,yaml}\" \".changeset/*.json\" && cargo fmt --all",
        "format:check": "prettier --check \"packages/**/*.{ts,tsx,js,mjs,cjs,scss,css,json}\" \"scripts/**/*.{js,mjs,cjs}\" \"*.{json,yml,yaml}\" \".changeset/*.json\" && cargo fmt --all --check",
        "prepare": "git config core.hooksPath .githooks || true"
    },
    "devDependencies": {
        "@changesets/cli": "^2.29.7",
        "prettier": "^3.4.2",
        "typescript": "^5.9.3"
    },
    "packageManager": "pnpm@9.15.0",
    "engines": {
        "node": ">=20.0.0"
    }
}
